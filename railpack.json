{
    "$schema": "https://railpack.com/schema.json",
    "providers": ["php"],
    "php": {
        "version": "8.3"
    },
    "build": {
        "commands": [
            "composer install --no-dev --optimize-autoloader",
            "npm install",
            "npm run build",
            "php artisan config:cache",
            "php artisan route:cache",
            "php artisan view:cache"
        ]
    },
    "start": {
        "command": "php artisan serve --host=0.0.0.0 --port=$PORT"
    }
}
